{
  "$schema": "https://raw.githubusercontent.com/nicedoc/schemas/master/tauri/tauri.conf.json",
  "productName": "ChessMentor",
  "version": "0.1.0",
  "identifier": "com.chessmentor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ChessMentor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/stockfish"
    ],
    "license": "GPL-3.0-only",
    "category": "Education",
    "shortDescription": "Learn chess with an adaptive AI coach",
    "longDescription": "ChessMentor is a chess learning app featuring adaptive coaching, tactical puzzles with spaced repetition, opening repertoire training, and game analysis powered by Stockfish.",
    "macOS": {
      "entitlements": "entitlements/ChessMentor.entitlements",
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0",
      "exceptionDomain": null
    }
  }
}
